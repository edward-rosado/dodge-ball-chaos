{
  "name": "dodge-ball-chaos",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:quick": "vitest run --exclude='**/beatability*'",
    "test:coverage": "vitest run --exclude='**/beatability*' --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf .next out node_modules",
    "setup": "npm install && npm run build",
    "test:beatability": "tsx scripts/test-beatability.ts",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
